{
  "name": "datacon",
  "version": "0.1.0",
  "private": true,
  "description": "Database Studio — multi-engine database and broker client",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsup --watch",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"wait-on http://localhost:5173 dist/main/index.js && electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsup",
    "build": "npm run build:renderer && npm run build:main",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "package": "npm run build && electron-builder --mac --publish never",
    "package:dir": "npm run build && electron-builder --dir --publish never"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.7",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "styled-components": "^6.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^25.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  }
}
